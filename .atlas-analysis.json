  "publicApiSurface": [
    "getAIStrategy() - Generate personalized DeFi strategies",
    "saveRiskProfile() - Save user risk profile on-chain",
    "getUserProfile() - Retrieve user profile from blockchain",
    "anchorStrategy() - Anchor AI strategy recommendation on-chain",
    "getStrategyCount() - Get total strategies for user",
    "useWallet() - React hook for wallet connection",
    "useAIAdvisor() - React hook for AI strategy generation",
    "usePortfolio() - React hook for portfolio data",
    "useProtocols() - React hook for protocol information",
    "PROTOCOLS - Array of supported DeFi protocols",
    "set-risk-profile - Clarity contract function",
    "save-strategy - Clarity contract function",
    "get-user-profile - Clarity read-only function",
    "get-strategy - Clarity read-only function"
